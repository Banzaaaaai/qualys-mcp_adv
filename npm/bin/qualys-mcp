#!/usr/bin/env node

const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');

const platformMap = { darwin: 'darwin', linux: 'linux', win32: 'windows' };
const archMap = { x64: 'amd64', arm64: 'arm64' };
const os = platformMap[process.platform] || process.platform;
const cpu = archMap[process.arch] || process.arch;
const ext = process.platform === 'win32' ? '.exe' : '';
const binPath = path.join(__dirname, `qualys-mcp-${os}-${cpu}${ext}`);

if (!fs.existsSync(binPath)) {
  console.error('qualys-mcp binary not found. Running install...');
  require('../scripts/install.js');
  process.exit(1);
}

const child = spawn(binPath, process.argv.slice(2), {
  stdio: 'inherit',
  env: process.env,
});

child.on('close', (code) => {
  process.exit(code);
});
