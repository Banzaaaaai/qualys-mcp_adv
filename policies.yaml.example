        "gav_list_assets",
        "gav_search_assets",
        "kb_get_qid",
        "kb_get_cve_mapping"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 200
    },
    "readonly": {
      "name": "readonly",
      "description": "Minimal read-only access for auditors",
      "allowed_tools": [
        "kb_get_qid",
        "kb_search_vulns",
        "kb_get_cve_mapping",
        "gav_list_tags"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 50
    },
    "deny-all": {
      "name": "deny-all",
      "description": "Deny all access (default for unknown users)",
      "allowed_tools": [],
      "denied_tools": ["*"],
      "rate_limit_per_min": 0
    }
  },
  "role_bindings": {
    "security-admin": ["admin"],
    "security-analyst": ["security-analyst"],
    "security-engineer": ["security-analyst"],
    "cloud-engineer": ["cloud-security"],
    "cloud-architect": ["cloud-security"],
    "container-developer": ["container-team"],
    "devops": ["container-team"],
    "patch-manager": ["patch-admin"],
    "it-operations": ["patch-admin"],
    "compliance-officer": ["compliance-auditor"],
    "auditor": ["compliance-auditor"],
    "appsec-engineer": ["appsec-team"],
    "penetration-tester": ["appsec-team"],
    "soc-analyst": ["soc-analyst"],
    "incident-responder": ["soc-analyst"],
    "viewer": ["readonly"],
    "anonymous": ["deny-all"]
  },
  "default_policy": "deny-all"
}
