{
  "policies": {
    "admin": {
      "name": "admin",
      "description": "Full access to all 56 tools",
      "allowed_tools": ["*"],
      "denied_tools": [],
      "rate_limit_per_min": 1000
    },
    "security-analyst": {
      "name": "security-analyst",
      "description": "Full read access to vulnerability, asset, and threat data",
      "allowed_tools": [
        "vmdr_list_hosts",
        "vmdr_get_host_detections",
        "vmdr_search_detections",
        "vmdr_list_scans",
        "vmdr_get_scan_results",
        "vmdr_list_asset_groups",
        "kb_get_qid",
        "kb_search_vulns",
        "kb_get_cve_mapping",
        "kb_list_recent_vulns",
        "gav_list_assets",
        "gav_search_assets",
        "gav_get_asset_details",
        "gav_list_tags",
        "gav_get_assets_by_tag",
        "cs_list_images",
        "cs_get_image_vulnerabilities",
        "cs_list_containers",
        "cs_search_images",
        "cs_get_image_details",
        "edr_list_events",
        "edr_list_indicators",
        "edr_list_assets",
        "edr_get_asset_events",
        "edr_search_events",
        "fim_list_events",
        "fim_list_profiles",
        "fim_list_assets",
        "fim_list_incidents",
        "fim_get_asset_events",
        "was_list_webapps",
        "was_list_scans",
        "was_list_findings",
        "was_get_webapp_findings",
        "was_list_reports"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 100,
      "arg_filters": {
        "query": { "max_length": 500 },
        "filter": { "max_length": 500 }
      }
    },
    "cloud-security": {
      "name": "cloud-security",
      "description": "Cloud security posture and CDR access",
      "allowed_tools": [
        "tc_list_connectors",
        "tc_list_resources",
        "tc_list_controls",
        "tc_list_evaluations",
        "tc_get_control_evaluations",
        "tc_get_resource_evaluations",
        "tc_list_cdr_findings",
        "gav_list_assets",
        "gav_search_assets",
        "kb_get_qid",
        "kb_search_vulns",
        "kb_get_cve_mapping"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 150
    },
    "container-team": {
      "name": "container-team",
      "description": "Container security tools for DevOps teams",
      "allowed_tools": [
        "cs_list_images",
        "cs_get_image_vulnerabilities",
        "cs_list_containers",
        "cs_search_images",
        "cs_get_image_details",
        "kb_get_qid",
        "kb_search_vulns",
        "kb_get_cve_mapping"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 200
    },
    "patch-admin": {
      "name": "patch-admin",
      "description": "Patch management access",
      "allowed_tools": [
        "pm_list_patches",
        "pm_list_assets",
        "pm_list_jobs",
        "pm_get_job_details",
        "pm_get_asset_patches",
        "vmdr_list_hosts",
        "vmdr_get_host_detections",
        "gav_list_assets",
        "gav_search_assets"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 100
    },
    "compliance-auditor": {
      "name": "compliance-auditor",
      "description": "Compliance and certificate monitoring",
      "allowed_tools": [
        "pc_list_policies",
        "pc_list_scans",
        "pc_get_policy_details",
        "pc_list_exceptions",
        "cert_list_certificates",
        "cert_get_expiring",
        "cert_list_endpoints",
        "cert_get_details",
        "cert_list_assets",
        "gav_list_assets",
        "gav_list_tags"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 75
    },
    "appsec-team": {
      "name": "appsec-team",
      "description": "Web application security access",
      "allowed_tools": [
        "was_list_webapps",
        "was_list_scans",
        "was_list_findings",
        "was_get_webapp_findings",
        "was_list_reports",
        "kb_get_qid",
        "kb_search_vulns",
        "kb_get_cve_mapping"
      ],
      "denied_tools": [],
      "rate_limit_per_min": 100
    },
    "soc-analyst": {
      "name": "soc-analyst",
      "description": "SOC analyst with EDR, FIM, and CDR access for threat hunting",
      "allowed_tools": [
        "edr_list_events",
        "edr_list_indicators",
